        {
          "name": "Update Lesson Progress",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 403\", function () {",
                  "    pm.expect([200, 403]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test(\"Response has progress data\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(jsonData.data).to.have.property('lesson_progress');",
                  "        pm.expect(jsonData.data).to.have.property('course_progress');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"watched_seconds\": 120,\n  \"is_completed\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/courses/{{course_slug}}/enrolled/lessons/{{lesson_slug}}/progress",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "courses",
                "{{course_slug}}",
                "enrolled",
                "lessons",
                "{{lesson_slug}}",
                "progress"
              ]
            },
            "description": "Update lesson progress (watched_seconds required, is_completed optional). Triggers course progress recalculation. Returns 403 if not enrolled."
          },
          "response": []
        }
      ],
